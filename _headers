# HTML entry points — never cache. The app ships as a single-page
# index.html with inline JS; if the browser caches it, deploys to
# fix bugs (like the orphan-record alerts) don't land until the
# user manually clears cache. no-cache + must-revalidate forces the
# browser to re-check with Cloudflare on every navigation; CF still
# holds its own edge cache so this stays fast. Other paths (JS/CSS
# modules under src/, manifest.json, push-sw.js) already use ?v=
# cache-busters in their URLs, so they're unaffected.
/
  Cache-Control: no-cache, must-revalidate
/index.html
  Cache-Control: no-cache, must-revalidate

rules_version = '2';
// ------------------------------------------------------------------
// Loopenta / LMI Tool — Firestore rules, PHASE 1
// Safe to paste today. Phase 1 locks down the high-value attack
// surfaces without breaking the app's existing unfiltered reads.
// ------------------------------------------------------------------
// PHASE 1 SCOPE
//
//   STRICT (bank-grade):
//     - users: privilege-escalation guard (cannot change own role,
//       orgId, tier, lockout state); admin-only list; superadmin-
//       only create/delete
//     - tenants / organizations: admin-write only; superadmin-list
//     - auditLog: immutable append-only
//     - agreementLog, email_log, scorecardSnapshots: immutable
//     - dataDeleteRequests: admin-only, immutable after creation
//     - invites: admin-create; one-shot acceptance only
//     - flyers: MLO create; admin delete
//     - passwordHistory, mfaRecoveryCodes: self-only, no deletion
//
//   SIGNED-IN-ONLY (Phase 1.5 will tighten):
//     - deals, prospects, realtors, oyz, prequal, activity,
//       notifications, sequences, sequenceEnrollments,
//       communications, email_templates, drip_campaigns,
//       drip_enrollments, call_log, tasks, craReports,
//       pastCustomers, realtor_searches, realtor_pushes
//
//     Rationale: the app today performs unfiltered `.get()` on
//     these collections in dashboards, aggregations, and admin
//     views. Strict per-doc orgId checks at the list level would
//     fail those queries. Requiring auth is still a huge upgrade
//     over `allow read, write: if true`. Tenant isolation for
//     these is enforced by the app's orgId filters client-side
//     until Phase 1.5 refactors the queries.
//
//   PUBLIC (by design):
//     - flyers GET (anonymous via opaque token)
//     - invites GET (anonymous via opaque token)
//     - auditLog CREATE (pre-auth failed-login logging)
//     - loginAttempts create/update (lockout counters pre-auth)
// ------------------------------------------------------------------

service cloud.firestore {
  match /databases/{database}/documents {

    // ================ HELPERS ================

    function isSignedIn() {
      return request.auth != null;
    }

    function userDocExists() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function callerOrg() {
      return userDocExists() ? userDoc().orgId : '';
    }

    function isSuperAdmin() {
      return userDocExists() && userDoc().role == 'superadmin';
    }

    function isTenantAdmin() {
      // App uses role == 'admin' for the in-tenant admin role.
      return userDocExists() && userDoc().role == 'admin';
    }

    function isAdmin() {
      return isSuperAdmin() || isTenantAdmin();
    }

    function isMlo() {
      return userDocExists() && (
        userDoc().role == 'mlo'
        || userDoc().role == 'admin'
        || userDoc().role == 'superadmin'
      );
    }

    // ── Expanded role helpers (Hub model, 2026-04-22) ─────────────
    // New roles introduced: manager, realtor (already existed),
    // referralUser, titleUser, escrowUser. 'mlo' kept as the stored
    // value for "Home Loan Advisor" — the field is renamed in UI only,
    // which keeps existing data valid.
    function isManager() {
      return userDocExists() && userDoc().role == 'manager';
    }

    function isRealtor() {
      return userDocExists() && userDoc().role == 'realtor';
    }

    function isHla() {
      // Alias: Home Loan Advisor. Stored as 'mlo' for back-compat.
      return userDocExists() && userDoc().role == 'mlo';
    }

    function isReferralUser() {
      return userDocExists() && userDoc().role == 'referralUser';
    }

    function isTitleUser() {
      return userDocExists() && userDoc().role == 'titleUser';
    }

    function isEscrowUser() {
      return userDocExists() && userDoc().role == 'escrowUser';
    }

    // Anyone who belongs to an org (i.e., not superadmin only) and is
    // a "producing" individual contributor or manager. Used for things
    // like creating leads, referral partnerships, etc.
    function isOrgMember() {
      return userDocExists() && (
        userDoc().role == 'admin'
        || userDoc().role == 'manager'
        || userDoc().role == 'mlo'
        || userDoc().role == 'realtor'
        || userDoc().role == 'referralUser'
        || userDoc().role == 'titleUser'
        || userDoc().role == 'escrowUser'
        || userDoc().role == 'superadmin'
      );
    }

    // Manager sees their direct reports. Used by users-list + reporting
    // screens. A "direct report" is any user in the same org whose
    // managerId field points at the caller's uid.
    function managesUser(targetUserData) {
      return isManager()
        && targetUserData.orgId == callerOrg()
        && targetUserData.managerId == request.auth.uid;
    }

    function inOrg(oid) {
      return userDocExists() && userDoc().orgId == oid;
    }

    function sameOrg(oid) {
      return isSuperAdmin() || inOrg(oid);
    }

    // Phase 2 tenant-isolation helpers. The app stores the tenant key as
    // either `orgId` (most operational collections) or `tenantId` (sequences,
    // scorecardSnapshots, securityEvents, agreementLog, auditLog). Both are
    // populated from the same currentUser.orgId at write time, so we accept
    // either field — whichever exists matches callerOrg(). Super-admins
    // bypass entirely so cross-tenant SA views keep working.
    function callerOwnsDoc(data) {
      return isSuperAdmin()
        || data.get('orgId', '__none__') == callerOrg()
        || data.get('tenantId', '__none__') == callerOrg();
    }
    // For update operations: the new doc must also belong to caller's org
    // (prevents cross-tenant move via update). Super-admins exempt.
    function orgScopePreserved() {
      return isSuperAdmin()
        || (
          resource.data.get('orgId', '__none__')
            == request.resource.data.get('orgId', '__none__')
          && resource.data.get('tenantId', '__none__')
            == request.resource.data.get('tenantId', '__none__')
        );
    }

    // ================ USERS ================
    // STRICT — privilege-escalation-proof.
    match /users/{userId} {
      // get: self, superadmin, tenant-admin of same org, or a
      // Manager whose team the target user belongs to.
      allow get: if isSignedIn() && (
        request.auth.uid == userId
        || isSuperAdmin()
        || (isTenantAdmin() && inOrg(resource.data.orgId))
        || managesUser(resource.data)
      );

      // list: admins only at the query level. Managers filter by
      // orgId + managerId on the client and re-check in rules via
      // the `get` above on individual docs if needed.
      allow list: if isAdmin() || isManager();

      // create: superadmin anywhere; tenant-admin within own org.
      allow create: if
        isSuperAdmin()
        || (isTenantAdmin() && request.resource.data.orgId == callerOrg());

      // self-update — cannot escalate privileges.
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
             'role', 'orgId', 'tier', 'tierLabel',
             'failedLoginCount', 'lockedUntil', 'superAdmin',
             'accountStatus', 'subscriptionStatus', 'subscriptionTier',
             'managerId'
           ]);

      // admin-update — tenant-admin within own org, or superadmin
      // anywhere. Tenant-admin cannot move users to another org and
      // CANNOT promote anyone to superadmin (audit found this gap:
      // a single tenant-admin could pivot laterally to global root
      // by flipping `role:'superadmin'` on any user in their org).
      allow update: if
        isSuperAdmin()
        || (
          isTenantAdmin()
          && inOrg(resource.data.orgId)
          && request.resource.data.orgId == resource.data.orgId
          && request.resource.data.role != 'superadmin'
          && request.resource.data.get('superAdmin', false) == false
        );

      allow delete: if isSuperAdmin();

      // --- user-scoped subcollections ---
      match /prefs/{prefId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      match /passwordHistory/{entryId} {
        allow read, create: if isSignedIn() && request.auth.uid == userId;
        allow update, delete: if false;
      }

      match /mfaRecoveryCodes/{codeId} {
        allow read, create, update: if isSignedIn() && request.auth.uid == userId;
        allow delete: if false;
      }
    }

    // ================ TENANTS / ORGANIZATIONS ================
    // STRICT — only admins can write tenant config.
    match /tenants/{tenantId} {
      allow get: if sameOrg(tenantId);
      allow list: if isSuperAdmin();
      allow create, delete: if isSuperAdmin();
      allow update: if isSuperAdmin()
        || (isTenantAdmin() && inOrg(tenantId));
    }

    match /organizations/{orgId} {
      allow get: if sameOrg(orgId);
      allow list: if isSuperAdmin();
      allow create, delete: if isSuperAdmin();
      allow update: if isSuperAdmin()
        || (isTenantAdmin() && inOrg(orgId));
    }

    // ================ INVITES (public token reads) ================
    // Invitee hits URL unauthenticated — get only, no list. Admin
    // creates/revokes. Acceptance flips used=false→true one time.
    match /invites/{token} {
      allow get: if true;
      allow list: if isAdmin();
      allow create: if isAdmin();
      allow update: if isSignedIn()
        && resource.data.used == false
        && request.resource.data.used == true
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['used', 'usedAt', 'usedBy']);
      allow delete: if isAdmin();
    }

    // ================ FLYERS (public token reads) ================
    match /flyers/{token} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isMlo();
      allow update, delete: if isAdmin();
    }

    // ================ AGREEMENTS (DPA / ToS) ================
    match /agreements/{agreementId} {
      allow get, list: if isSignedIn();
      allow create, update: if isSuperAdmin();
      allow delete: if false;
    }

    // Immutable: signed log of agreement signings.
    match /agreementLog/{logId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ================ AUDIT LOG (immutable) ================
    // Nobody reads without admin; nobody ever updates or deletes.
    // Create is gated to prevent forged-actor entries (previously
    // `if true` let any signed-in user write a log entry claiming
    // to be the CEO or to belong to another tenant — see audit).
    //
    // Two valid create paths:
    //   1. Signed-in entries — userId/userName/tenantId MUST match
    //      the caller's auth uid + org. The client cannot lie about
    //      who acted.
    //   2. Pre-auth security entries — only a small whitelist of
    //      actions (failed-login telemetry) can be written without
    //      a session. Those entries MUST NOT carry a userId, so
    //      they can never impersonate a real user.
    match /auditLog/{logId} {
      allow get, list: if isAdmin();
      allow create: if (
        // Signed-in: actor is pinned to the caller.
        (isSignedIn()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.get('tenantId', '') == callerOrg())
        // Pre-auth: only failed-login telemetry, no userId field.
        || (
          request.resource.data.action in [
            'login_failed', 'login_throttled', 'login_locked_out',
            'login_recovery_requested'
          ]
          && !('userId' in request.resource.data)
        )
      );
      allow update, delete: if false;
    }

    // ================ LOGIN ATTEMPTS (lockout counters) ================
    // Pre-auth writable by design — the failed-login handler needs
    // to increment counters BEFORE the caller has a session. Keep
    // the doc shape minimal (counter + windowStart + lockedUntil).
    match /loginAttempts/{key} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update: if true;
      allow delete: if isSuperAdmin();
    }

    // ================ SECURITY EVENTS (immutable) ================
    match /securityEvents/{evtId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ================ DATA DELETE REQUESTS (GDPR/CCPA) ================
    match /dataDeleteRequests/{reqId} {
      allow get, list, create: if isAdmin();
      allow update, delete: if false;
    }

    // (email_log, scorecardSnapshots, craReports moved into the
    // tenant-isolated block below. Removing the old looser duplicate
    // match blocks prevents them from OR-merging with the strict
    // versions and re-opening cross-tenant access.)

    // =================================================================
    // OPERATIONAL COLLECTIONS — TENANT-ISOLATED (Phase 2)
    //
    // Every collection below now requires the caller to be in the same
    // org as the doc (orgId or tenantId, whichever the doc carries).
    // Cross-tenant reads are blocked at the database level — the previous
    // "filter client-side" approach failed open because any user could
    // open DevTools and skip the filter.
    //
    // CLIENT REQUIREMENT: list queries MUST include
    //   .where('orgId','==', currentUser.orgId)
    // (or 'tenantId' for sequences/scorecardSnapshots). An unfiltered
    // .get() will now return permission_denied because some docs in the
    // result fail the per-doc rule. _scopeOrg() in index.html handles
    // this — every caller threads through it. Super-admins bypass
    // because callerOwnsDoc() short-circuits on isSuperAdmin().
    //
    // ROLLBACK: if a dashboard breaks after deploy, revert this file
    // to the previous commit (firestore.rules @ 2836a8a) and re-deploy.
    // Client code keeps working under the older rules — the .where()
    // clauses just become harmless extra filters.
    // =================================================================

    match /deals/{dealId} {
      allow get, list: if isSignedIn() && callerOwnsDoc(resource.data);
      allow create: if isSignedIn() && callerOwnsDoc(request.resource.data);
      allow update: if isSignedIn()
        && callerOwnsDoc(resource.data)
        && orgScopePreserved();
      allow delete: if isAdmin() && callerOwnsDoc(resource.data);
    }

    match /prospects/{prospectId} {
      allow get, list: if isSignedIn() && callerOwnsDoc(resource.data);
      allow create: if isSignedIn() && callerOwnsDoc(request.resource.data);
      allow update: if isSignedIn()
        && callerOwnsDoc(resource.data)
        && orgScopePreserved();
      allow delete: if isSignedIn() && callerOwnsDoc(resource.data);
    }

    match /pastCustomers/{customerId} {
      allow get, list: if isSignedIn() && callerOwnsDoc(resource.data);
      allow create: if isMlo() && callerOwnsDoc(request.resource.data);
      allow update: if isMlo()
        && callerOwnsDoc(resource.data)
        && orgScopePreserved();
      allow delete: if isMlo() && callerOwnsDoc(resource.data);
    }

    match /realtors/{realtorId} {
      allow get, list: if isSignedIn() && callerOwnsDoc(resource.data);
      allow create: if isSignedIn() && callerOwnsDoc(request.resource.data);
      allow update: if isSignedIn()
        && callerOwnsDoc(resource.data)
        && orgScopePreserved();
      allow delete: if isAdmin() && callerOwnsDoc(resource.data);
    }

    match /realtor_searches/{searchId} {
      allow get, list: if isSignedIn() && callerOwnsDoc(resource.data);
      allow create: if isSignedIn() && callerOwnsDoc(request.resource.data);
      allow update: if isSignedIn()
        && callerOwnsDoc(resource.data)
        && orgScopePreserved();
      allow delete: if isAdmin() && callerOwnsDoc(resource.data);
    }

    match /realtor_pushes/{pushId} {
      allow get, list: if isSignedIn() && callerOwnsDoc(resource.data);
      allow create: if isSignedIn() && callerOwnsDoc(request.resource.data);
      allow update: if isSignedIn()
        && callerOwnsDoc(resource.data)
        && orgScopePreserved();
      allow delete: if isAdmin() && callerOwnsDoc(resource.data);
    }

    match /oyz/{oyzId} {
      allow get, list: if isSignedIn() && callerOwnsDoc(resource.data);
      allow create: if isSignedIn() && callerOwnsDoc(request.resource.data);
      allow update: if isSignedIn()
        && callerOwnsDoc(resource.data)
        && orgScopePreserved();
      // Was open to any signed-in user; now requires caller to own the doc.
      allow delete: if isSignedIn() && callerOwnsDoc(resource.data);
    }

    match /prequal/{prequalId} {
      allow get, list: if isSignedIn() && callerOwnsDoc(resource.data);
      allow create: if isSignedIn() && callerOwnsDoc(request.resource.data);
      allow update: if isSignedIn()
        && callerOwnsDoc(resource.data)
        && orgScopePreserved();
      allow delete: if isAdmin() && callerOwnsDoc(resource.data);
    }

    match /activity/{activityId} {
      allow get, list: if isSignedIn() && callerOwnsDoc(resource.data);
      allow create: if isSignedIn() && callerOwnsDoc(request.resource.data);
      allow update: if isAdmin()
        && callerOwnsDoc(resource.data)
        && orgScopePreserved();
      allow delete: if isAdmin() && callerOwnsDoc(resource.data);
    }

    match /notifications/{notifId} {
      allow get, list: if isSignedIn() && callerOwnsDoc(resource.data);
      allow create: if isSignedIn() && callerOwnsDoc(request.resource.data);
      allow update: if isSignedIn()
        && callerOwnsDoc(resource.data)
        && orgScopePreserved();
      allow delete: if isSignedIn() && callerOwnsDoc(resource.data);
    }

    match /sequences/{seqId} {
      allow get, list: if isSignedIn() && callerOwnsDoc(resource.data);
      allow create: if isSignedIn() && callerOwnsDoc(request.resource.data);
      allow update: if isSignedIn()
        && callerOwnsDoc(resource.data)
        && orgScopePreserved();
      // Was open to any signed-in user; now requires caller to own the doc.
      allow delete: if isSignedIn() && callerOwnsDoc(resource.data);
    }

    match /sequenceEnrollments/{enrollId} {
      allow get, list: if isSignedIn() && callerOwnsDoc(resource.data);
      allow create: if isSignedIn() && callerOwnsDoc(request.resource.data);
      allow update: if isSignedIn()
        && callerOwnsDoc(resource.data)
        && orgScopePreserved();
      allow delete: if isSignedIn() && callerOwnsDoc(resource.data);
    }

    match /communications/{commId} {
      allow get, list: if isSignedIn() && callerOwnsDoc(resource.data);
      allow create: if isSignedIn() && callerOwnsDoc(request.resource.data);
      allow update: if isSignedIn()
        && callerOwnsDoc(resource.data)
        && orgScopePreserved();
      allow delete: if isAdmin() && callerOwnsDoc(resource.data);
    }

    match /tasks/{taskId} {
      allow get, list: if isSignedIn() && callerOwnsDoc(resource.data);
      allow create: if isSignedIn() && callerOwnsDoc(request.resource.data);
      allow update: if isSignedIn()
        && callerOwnsDoc(resource.data)
        && orgScopePreserved();
      allow delete: if isSignedIn() && callerOwnsDoc(resource.data);
    }

    match /call_log/{logId} {
      allow get, list: if isSignedIn() && callerOwnsDoc(resource.data);
      allow create: if isSignedIn() && callerOwnsDoc(request.resource.data);
      allow update: if isSignedIn()
        && callerOwnsDoc(resource.data)
        && orgScopePreserved();
      allow delete: if isSignedIn() && callerOwnsDoc(resource.data);
    }

    match /craReports/{reportId} {
      allow get, list: if isSignedIn() && callerOwnsDoc(resource.data);
      allow create: if isAdmin() && callerOwnsDoc(request.resource.data);
      allow update: if isAdmin()
        && callerOwnsDoc(resource.data)
        && orgScopePreserved();
      allow delete: if isSuperAdmin();
    }

    match /scorecardSnapshots/{snapId} {
      allow get, list: if isSignedIn() && callerOwnsDoc(resource.data);
      allow create: if isSignedIn() && callerOwnsDoc(request.resource.data);
      allow update: if isAdmin()
        && callerOwnsDoc(resource.data)
        && orgScopePreserved();
      allow delete: if false;
    }

    match /email_log/{logId} {
      allow get, list: if isSignedIn() && callerOwnsDoc(resource.data);
      allow create: if isSignedIn() && callerOwnsDoc(request.resource.data);
      allow update: if isAdmin()
        && callerOwnsDoc(resource.data)
        && orgScopePreserved();
      allow delete: if false;
    }

    match /email_templates/{tplId} {
      allow get, list: if isSignedIn() && callerOwnsDoc(resource.data);
      allow create: if isSignedIn() && callerOwnsDoc(request.resource.data);
      allow update: if isSignedIn()
        && callerOwnsDoc(resource.data)
        && orgScopePreserved();
      allow delete: if isAdmin() && callerOwnsDoc(resource.data);
    }

    match /drip_campaigns/{campId} {
      allow get, list: if isSignedIn() && callerOwnsDoc(resource.data);
      allow create: if isSignedIn() && callerOwnsDoc(request.resource.data);
      allow update: if isSignedIn()
        && callerOwnsDoc(resource.data)
        && orgScopePreserved();
      allow delete: if isAdmin() && callerOwnsDoc(resource.data);
    }

    match /drip_enrollments/{enrId} {
      allow get, list: if isSignedIn() && callerOwnsDoc(resource.data);
      allow create: if isSignedIn() && callerOwnsDoc(request.resource.data);
      allow update: if isSignedIn()
        && callerOwnsDoc(resource.data)
        && orgScopePreserved();
      allow delete: if isSignedIn() && callerOwnsDoc(resource.data);
    }

    match /dealDocuments/{docId} {
      allow get, list: if isSignedIn() && callerOwnsDoc(resource.data);
      allow create: if isSignedIn() && callerOwnsDoc(request.resource.data);
      allow update: if isSignedIn()
        && callerOwnsDoc(resource.data)
        && orgScopePreserved();
      allow delete: if isAdmin() && callerOwnsDoc(resource.data);
    }

    // ========================================================
    // HUB (2026-04-22): cross-org referrals, leads, listings,
    // buyers, shared deals, deal documents.
    // ========================================================

    // referralLinks: agreements between two orgs to send/receive referrals
    match /referralLinks/{linkId} {
      allow read: if isSignedIn() && (
        isSuperAdmin()
        || resource.data.orgAId == callerOrg()
        || resource.data.orgBId == callerOrg()
        || resource.data.invitedEmail == request.auth.token.email
      );
      allow create: if isSignedIn() && (
        isAdmin()
        || isManager()
        || request.resource.data.orgAId == callerOrg()
      );
      allow update: if isSignedIn() && (
        isSuperAdmin()
        || resource.data.orgAId == callerOrg()
        || resource.data.orgBId == callerOrg()
        || resource.data.invitedEmail == request.auth.token.email
      );
      allow delete: if isAdmin() || isSuperAdmin();
    }

    // leads: a referred opportunity moving between orgs.
    // Lifecycle fields (status, stage, timeline[], lastReadBy, viewedAt,
    // closedAt, stageUpdatedAt, stageUpdatedBy) are all writable by either
    // side — "both sides can update" model. Creator org is immutable.
    match /leads/{leadId} {
      allow read: if isSignedIn() && (
        isSuperAdmin()
        || resource.data.fromOrgId == callerOrg()
        || resource.data.toOrgId == callerOrg()
        || resource.data.fromUserId == request.auth.uid
        || resource.data.toUserId == request.auth.uid
      );
      allow create: if isSignedIn()
        && request.resource.data.fromOrgId == callerOrg()
        && request.resource.data.fromUserId == request.auth.uid;
      allow update: if isSignedIn() && (
        isSuperAdmin()
        || resource.data.fromOrgId == callerOrg()
        || resource.data.toOrgId == callerOrg()
      ) && (
        // Immutable identity fields — can't be changed on update.
        isSuperAdmin() || (
          request.resource.data.fromOrgId == resource.data.fromOrgId
          && request.resource.data.fromUserId == resource.data.fromUserId
          && request.resource.data.toOrgId == resource.data.toOrgId
          && request.resource.data.createdAt == resource.data.createdAt
        )
      );
      allow delete: if isAdmin() || isSuperAdmin();
    }

    // hubNotifications: per-user in-app notification feed.
    // Target user reads & marks read; any signed-in user touching a lead
    // can create (status changes, notes on their referrals produce notifs).
    match /hubNotifications/{notifId} {
      allow read: if isSignedIn() && (
        isSuperAdmin()
        || resource.data.targetUid == request.auth.uid
      );
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.targetUid is string
        && request.resource.data.targetUid.size() > 0;
      // Only the target can update (mark-as-read) or delete.
      allow update, delete: if isSignedIn() && (
        isSuperAdmin()
        || resource.data.targetUid == request.auth.uid
      );
    }

    // pushSubscriptions: Web Push endpoints keyed by user.
    // A user owns only their own subscription records.
    match /pushSubscriptions/{subId} {
      allow read, update, delete: if isSignedIn() && (
        isSuperAdmin()
        || resource.data.uid == request.auth.uid
      );
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
    }

    // notificationPrefs: per-user email/push opt-in settings.
    match /notificationPrefs/{uid} {
      allow read: if isSignedIn() && (isSuperAdmin() || uid == request.auth.uid);
      allow create, update: if isSignedIn() && uid == request.auth.uid;
      allow delete: if isSuperAdmin();
    }

    // listings: realtor inventory, optionally LMI-flagged
    match /listings/{listingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.orgId == callerOrg();
      allow update, delete: if isSignedIn() && (
        isSuperAdmin()
        || resource.data.orgId == callerOrg()
      );
    }

    // buyers: realtor buyer pipeline
    match /buyers/{buyerId} {
      allow read: if isSignedIn() && (
        isSuperAdmin()
        || resource.data.orgId == callerOrg()
      );
      allow create: if isSignedIn()
        && request.resource.data.orgId == callerOrg();
      allow update, delete: if isSignedIn() && (
        isSuperAdmin()
        || resource.data.orgId == callerOrg()
      );
    }

    // sharedDeals: co-working deal workspace between two orgs
    match /sharedDeals/{dealId} {
      allow read, update: if isSignedIn() && (
        isSuperAdmin()
        || resource.data.lenderOrgId == callerOrg()
        || resource.data.realtyOrgId == callerOrg()
      );
      allow create: if isSignedIn() && (
        request.resource.data.lenderOrgId == callerOrg()
        || request.resource.data.realtyOrgId == callerOrg()
      );
      allow delete: if isAdmin() || isSuperAdmin();
    }

    // dealDocuments: files attached to a sharedDeal or lead
    match /dealDocuments/{docId} {
      allow read, create, update: if isSignedIn();
      allow delete: if isAdmin() || isSuperAdmin();
    }

    // ========================================================
    // Deny everything else
    // ========================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

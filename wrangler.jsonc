{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lmi-tool",
  "main": "worker.js",
  "compatibility_date": "2026-04-17",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  }
  // KV binding — configure in Cloudflare dashboard:
  // Workers & Pages → lmi-tool → Settings → Variables → KV Namespace Bindings
  // Variable name: KV_NAMESPACE  →  Namespace: LMI_PROPERTY_CACHE
}
